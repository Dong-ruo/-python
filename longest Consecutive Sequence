#给定未排序数组，找到最长连续数字序列。
#eg
nums = [100,4,200,1,3,2]
最长序列：1,2,3,4
输出：4

#思路：使用set,只从序列起来开始扩展：：：num-1 不存在

def longestConsecutive(nums):

    num_set = set(nums)
    longest = 0

    for num in num_set:

        if num - 1 not in num_set:

            current = num
            length = 1

            while current + 1 in num_set:
                current += 1
                length += 1

            longest = max(longest, length)

    return longest
